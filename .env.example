# 🤖 Aether Multi-Agent Bot Configuration
# ⚠️ NEVER COMMIT THIS FILE TO GIT!

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI Model API Keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
MISTRAL_API_KEY=your_mistral_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# AI Server URLs
MISTRAL_SERVER_URL=http://127.0.0.1:8004
GROQ_SERVER_URL=http://127.0.0.1:8004
GEMINI_SERVER_URL=http://127.0.0.1:8004

# TON Blockchain API (Chainstack)
TON_API_URL=https://ton-testnet.core.chainstack.com/ВАШ_НОВЫЙ_КЛЮЧ/api/v2
TON_API_KEY=ВАШ_НОВЫЙ_КЛЮЧ_от_Chainstack

# Database (optional)
DATABASE_URL=sqlite:///./bot.db

# Other settings
DEBUG=false
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT=10
RATE_LIMIT_WINDOW=60

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_PASS=your-redis-password-here
REDIS_DB=0

# Monitoring Configuration
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=your-grafana-password-here

# Application Configuration
APP_PORT=8080
APP_HOST=0.0.0.0
DEBUG=false

# Security & Audit
AUDIT_LOG=audit.log
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-here-min-32-chars

# Session Management
SESSION_TIMEOUT=3600
MAX_SESSIONS=100
SESSION_MEMORY_LIMIT=1000

# AI Model Configuration
DEFAULT_MODEL=claude
MODEL_TIMEOUT=30
MAX_TOKENS=4000
TEMPERATURE=0.7

# Docker Configuration
COMPOSE_PROJECT_NAME=aether-bot
COMPOSE_FILE=docker-compose.yml

# Server Configuration (for deployment)
SERVER_HOST=your-server-ip-here
SERVER_USER=ubuntu
SERVER_SSH_KEY_PATH=~/.ssh/id_rsa

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# Alert Configuration
ALERT_WEBHOOK_URL=your-webhook-url-here
ALERT_EMAIL=your-email-here

# Development Configuration
DEV_MODE=false
TEST_MODE=false
MOCK_AI=false

# Database Configuration (if needed)
DATABASE_URL=sqlite:///./bot.db

# File Storage
UPLOAD_DIR=uploads/
MAX_FILE_SIZE=10485760  # 10MB

# Feature Flags
ENABLE_MONITORING=true
ENABLE_ALERTS=true
ENABLE_AUDIT=true
ENABLE_CACHE=true
ENABLE_SESSIONS=true

# Performance Configuration
WORKER_PROCESSES=4
MAX_CONNECTIONS=1000
KEEPALIVE_TIMEOUT=65

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400  # 24 hours
BACKUP_RETENTION=7  # days

# Security Headers
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*
